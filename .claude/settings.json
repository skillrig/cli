{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/ascii-guard.sh\"",
            "statusMessage": "non-ASCII source guard",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
